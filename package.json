{
  "name": "melodown",
  "version": "1.2.0",
  "description": "YouTube audio downloader",
  "author": "Melodown",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "make": "electron-forge make --targets @electron-forge/maker-zip"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "name": "Melodown"
      },
      "makers": [
        {
          "name": "@electron-forge/maker-zip",
          "platforms": ["win32", "darwin"]
        }
      ]
    }
  },
  "devDependencies": {
    "electron": "33.0.0",
    "@electron-forge/cli": "^7.0.0",
    "@electron-forge/maker-zip": "^7.0.0",
    "@electron-forge/publisher-github": "^7.0.0"
  }
}
